# =============================================================================
# train_config_h100.env — Gen3R GRPO 16×H100 训练参数集中配置
#
# 用法：
#   修改本文件后直接 `bash run_train_h100_16gpu.sh`，脚本会 source 这里。
#
# 覆盖优先级（高 → 低）：
#   命令行 env > 本 config > 启动脚本兜底默认
#   例：临时关 KL：              KL_COEFF=0 bash run_train_h100_16gpu.sh
#   例：节点 0 启动多机训练：    MASTER_ADDR=10.0.0.1 NODE_RANK=0 bash run_train_h100_16gpu.sh
#
# 实现说明：所有变量都用 ${VAR:-default} 形式赋值，确保命令行 env 可以覆盖。
# 如果你想把 config 里的值变成"硬性"（不允许命令行覆盖），把 ${VAR:-X} 改成裸 X 即可。
# =============================================================================


# ─── 路径 ─────────────────────────────────────────────────────────────────────
# 容器内 AFS 挂载多了一层 visitor16，用 ROOT 统一适配：
# • 本机/Cursor 环境：/mnt/afs/visitor16/rl_train_new
# • 平台容器内：      /mnt/afs/visitor16/visitor16/rl_train_new
_AFS_BASE="/mnt/afs/visitor16"
if [ -d "$_AFS_BASE/visitor16/rl_train_new" ]; then
    ROOT="${ROOT:-$_AFS_BASE/visitor16/rl_train_new}"
else
    ROOT="${ROOT:-$_AFS_BASE/rl_train_new}"
fi

# 数据根目录（manifest 中 sample_dir 已是绝对路径，所以 DATA_ROOT 仅用于兼容/日志）
DATA_ROOT="${DATA_ROOT:-$ROOT/hf_datasets/rl_data/gen3r}"

# ★ 训练 manifest（推荐用法）：每行一个 sample 的 jsonl
#   3200 条 = 1600 dl3dv + 1600 scannet++，每条 prompt_embed.pt / neg_embed.pt 已就位
TRAIN_MANIFEST="${TRAIN_MANIFEST:-$DATA_ROOT/merged_train_manifest.jsonl}"

# 用于过滤 manifest 中 dataset 字段；保持当前两个数据集
DATASETS="${DATASETS:-dl3dv,scannet++}"

# Gen3R 主模型 checkpoints（含 transformer / wan_vae / clip_image_encoder）
PRETRAINED_MODEL_PATH="${PRETRAINED_MODEL_PATH:-$ROOT/model/Gen3R/checkpoints}"

# Gen3R 推理 yaml（patch size / cfg 模板等）
CONFIG_PATH="${CONFIG_PATH:-$(dirname "${BASH_SOURCE[0]}")/Gen3R/gen3r/config/gen3r.yaml}"

# 输出根：每次启动会自动追加 _<时间戳>
OUTPUT_DIR_BASE="${OUTPUT_DIR_BASE:-$ROOT/_runs/grpo_h100_16gpu}"


# ─── 分布式 ───────────────────────────────────────────────────────────────────
# ★ 你的部署：2 节点 × 8 卡 = 16 卡 H100
#   两台机器都用同一份 config，唯一区别是启动时传不同 NODE_RANK：
#     节点 0：NODE_RANK=0 MASTER_ADDR=<节点0_IP> bash run_train_h100_16gpu.sh
#     节点 1：NODE_RANK=1 MASTER_ADDR=<节点0_IP> bash run_train_h100_16gpu.sh
#   或用脚手架：bash launch_2node.sh 0  /  bash launch_2node.sh 1
#
#   MASTER_ADDR 必须是「节点 0」的 IB / 机内可达 IP，**不是** localhost。
#   两机时间务必对齐 (chrony/ntpd)；防火墙必须放开 MASTER_PORT 与 NCCL 端口段。
NNODES="${NNODES:-2}"                          # 总节点数（debug=1, 生产=2）
NODE_RANK="${NODE_RANK:-0}"                    # 当前节点 rank（启动命令必须按节点指定）
NPROC_PER_NODE="${NPROC_PER_NODE:-8}"          # 每节点 GPU 数（debug=4, 生产=8）
MASTER_ADDR="${MASTER_ADDR:-localhost}"        # ★ 多机时必须改成节点 0 的 IP
MASTER_PORT="${MASTER_PORT:-29500}"            # 任意未被占用端口；两节点用同一个值


# ─── GRPO Batch（核心配置）────────────────────────────────────────────────────
# 每 step 总 rollout = R × NPROC_PER_NODE × NNODES
#   16 卡：R=4 → 64 rollout/step = 8 group × 8 rollout/group ← 你的目标配置
#    8 卡：R=4 → 32 rollout/step = 4 group × 8 rollout/group
NUM_GENERATIONS="${NUM_GENERATIONS:-8}"        # G：每个 prompt 的 rollout 数
ROLLOUTS_PER_RANK="${ROLLOUTS_PER_RANK:-4}"    # R：每张卡的 rollout 数
                                                #   要求 NUM_GENERATIONS % ROLLOUTS_PER_RANK == 0
                                                #   ranks_per_group = G/R = 2（每 2 卡共享 1 prompt）

SAMPLING_STEPS="${SAMPLING_STEPS:-50}"         # SDE 去噪总步数

# ── 每卡 prompt 数（train_batch_size）────────────────────────────────────────
# 控制每张卡每 step 处理几个不同的 prompt，与 ROLLOUTS_PER_RANK 正交：
#   每 step 总 rollout = ROLLOUTS_PER_RANK × NNODES × NPROC_PER_NODE × TRAIN_BATCH_SIZE
#
# 典型配置示例（G=8, R=4）：
#   16 卡 + BS=1 → 每卡 1 prompt × 4 rollout，2 卡共享 1 prompt（ranks_per_group=2），8 prompt/step
#   16 卡 + BS=2 → 每卡 2 prompt × 4 rollout，2 卡共享 1 prompt，16 prompt/step （吞吐翻倍）
#    4 卡 + BS=2 → 每卡 2 prompt × 4 rollout，2 卡共享 1 prompt，4 prompt/step
#    4 卡 + BS=4 → 每卡 4 prompt × 4 rollout，ranks_per_group=2，8 prompt/step （等效 16 卡 BS=1）
#
# 注意：BS>1 时 P1 latent 存储 & reward worker 任务数均线性增长，显存相应增加。
TRAIN_BATCH_SIZE="${TRAIN_BATCH_SIZE:-1}"

TRAIN_MICROBATCH_SIZE="${TRAIN_MICROBATCH_SIZE:-1}"   # P3 一次 fwd 的 rollout 拼批数
                                                #   1 = 老逻辑（卡内逐条），4 = 全 4 条一次


# ─── KL 散度（接口可调；0=完全跳过）─────────────────────────────────────────
KL_COEFF="${KL_COEFF:-0}"                      # 0     → 完全跳过 KL（ref_transformer 不加载）
                                                # 0.001 → 弱 KL
                                                # 0.01  → 推荐起始
                                                # 0.1   → 强 KL


# ─── Checkpoint 策略 ────────────────────────────────────────────────────────
ROLLING_CKPT_EVERY="${ROLLING_CKPT_EVERY:-4}"      # 每 N 步存一次滚动 ckpt（覆盖上一次）
PERMANENT_CKPT_EVERY="${PERMANENT_CKPT_EVERY:-50}" # 每 N 步存一次永久 ckpt（不删）
KEEP_LAST_N_PERMANENT="${KEEP_LAST_N_PERMANENT:-0}" # 0 = 永久 ckpt 不限数量


# ─── Resume / 断点续训 ─────────────────────────────────────────────────────
# RESUME_FROM 控制启动时是否加载 ckpt + 跳过已用样本
#   ""       (空字符串) = 全新训练，OUTPUT_DIR 自动追加时间戳新建
#   "auto"   = 在 OUTPUT_DIR_BASE_<上次时间戳>/ 下找最新 ckpt 续训；复用旧 OUTPUT_DIR
#   <path>   = 显式指定 ckpt 目录（如 ".../rolling-80"）；OUTPUT_DIR 用其父目录
# 续训会还原 model 权重 + global_step + sampler_seed，自动跳过已用过的样本，
# 但 optimizer / scheduler 状态不持久化（恢复后前几步 loss 会短暂抖动属正常）。
RESUME_FROM="${RESUME_FROM:-}"


# ─── 训练循环 ───────────────────────────────────────────────────────────────
MAX_TRAIN_STEPS="${MAX_TRAIN_STEPS:-200}"
LEARNING_RATE="${LEARNING_RATE:-1e-4}"
WEIGHT_DECAY="${WEIGHT_DECAY:-1e-4}"
MAX_GRAD_NORM="${MAX_GRAD_NORM:-1.0}"
LR_SCHEDULER="${LR_SCHEDULER:-constant_with_warmup}"
LR_WARMUP_STEPS="${LR_WARMUP_STEPS:-5}"
SEED="${SEED:-42}"


# ─── 数据 ────────────────────────────────────────────────────────────────────
NUM_FRAMES="${NUM_FRAMES:-49}"
FRAME_STRIDE="${FRAME_STRIDE:-1}"
RESOLUTION="${RESOLUTION:-560}"
FRAME_MODE="${FRAME_MODE:-video}"
DATALOADER_NUM_WORKERS="${DATALOADER_NUM_WORKERS:-4}"


# ─── GRPO 算法超参（不常调）────────────────────────────────────────────────
ETA="${ETA:-0.5}"                              # SDE 噪声强度
SHIFT="${SHIFT:-2.0}"                          # sigma schedule 偏移（DanceGRPO 风格）
# ── CFG 关闭（compare_sde 实验确认：cfg=1 与 cfg=6 视频清晰度差距甚小，
#    关掉 cfg 可省一次 unconditional 前向 → rollout/train 时间约减半）──
CFG_ROLLOUT="${CFG_ROLLOUT:-1.0}"              # 1.0 = 不用 CFG（rollout）
CFG_TRAIN="${CFG_TRAIN:-1.0}"                  # 1.0 = 不用 CFG（train 重算 logp）
TRAIN_TIMESTEP_STRATEGY="${TRAIN_TIMESTEP_STRATEGY:-front}"
# ── SDE=30：rollout 50 步中前 30 步走 SDE（记录 log_prob），后 20 步走 ODE
#    （收尾 → 视频清晰；avoid 之前 sde_fraction=1.0 末段噪声残留导致的糊视频问题）。
#    K = sampling_steps × sde_fraction = 50 × 0.6 = 30 → 与 train_steps_count=30 对齐
SDE_FRACTION="${SDE_FRACTION:-0.6}"            # 0.6 → 30 步 SDE + 20 步 ODE
TRAIN_STEPS_COUNT="${TRAIN_STEPS_COUNT:-30}"   # 训练时对全部 30 个 SDE timestep 算梯度
CLIP_RANGE="${CLIP_RANGE:-1e-4}"               # GRPO ratio 裁剪 ε（每 batch 只更新一次 → 实际不会触发）
ADV_CLIP_MAX="${ADV_CLIP_MAX:-5.0}"            # advantage 裁剪上限
VAE_DECODE_MICRO_BATCH="${VAE_DECODE_MICRO_BATCH:-4}"   # P1 末尾 VAE decode 的 micro batch


# ─── 显存优化 ────────────────────────────────────────────────────────────────
GRADIENT_CHECKPOINT_LAYERS="${GRADIENT_CHECKPOINT_LAYERS:-22}"
                                                # 选择性 per-block 梯度 ckpt 数（30 个 block 中开 N 个）
                                                # 22 = H100 80G 上 4 rollout × 30 train_T 的安全配置
                                                # -1 = 全开（最保险但慢 ~8%）
                                                #  0 = 全关（最快但峰值最高）


# ─── Reward ─────────────────────────────────────────────────────────────────
REWARD_DISPATCH_MODE="${REWARD_DISPATCH_MODE:-workers}"
REWARDS="${REWARDS:-geo_global,feature_sim,camera_traj,video_quality}"

# VideoAlign batch chunking（重要：单卡 vs 多卡区别）
#   0 = 一次性把全部 N=R*train_batch_size 条 rollout 真 batch（多卡训练默认；
#       VideoAlign 独占一张 H100，N=4 完全装得下）
#   2 = 每次只送 2 条进 inferencer.reward(...)，串行跑完所有 chunk
#       （单卡 smoke 必须用这个，否则 N=8 的 Qwen2-VL attention 会要 36 GiB）
#   1 = 完全串行（最保险，最慢）
VA_MICRO_BATCH="${VA_MICRO_BATCH:-0}"


# ─── 环境变量（PyTorch / NCCL / wandb）─────────────────────────────────────
export PYTORCH_CUDA_ALLOC_CONF="${PYTORCH_CUDA_ALLOC_CONF:-expandable_segments:True}"

# ─── NCCL 多机（2 节点跨机通信）──────────────────────────────────────────────
# 出问题先把 NCCL_DEBUG=INFO 打开看握手日志
export NCCL_DEBUG="${NCCL_DEBUG:-WARN}"
export NCCL_DEBUG_SUBSYS="${NCCL_DEBUG_SUBSYS:-INIT,NET,GRAPH}"

# NCCL watchdog：默认 10 分钟，rollout 一步可能 5-15 分钟，必须调长
export TORCH_NCCL_HEARTBEAT_TIMEOUT_SEC="${TORCH_NCCL_HEARTBEAT_TIMEOUT_SEC:-14400}"   # 4h
export TORCH_NCCL_BLOCKING_WAIT="${TORCH_NCCL_BLOCKING_WAIT:-0}"
export NCCL_BLOCKING_WAIT="${NCCL_BLOCKING_WAIT:-0}"
export NCCL_ASYNC_ERROR_HANDLING="${NCCL_ASYNC_ERROR_HANDLING:-1}"

# ─── 网卡选择（多机必看）────────────────────────────────────────────────────
# 如果 NCCL 默认网卡选错（譬如选了 docker0 / 管理网），需要显式指定：
#   1) 看可用网卡：    ip -o link show | awk -F': ' '{print $2}'
#   2) 看 IB 卡：      ibstat | grep -E "^CA"
# 例（按你的环境取消注释 + 改卡名）：
# export NCCL_SOCKET_IFNAME="eth0"        # TCP fallback / control plane 用的网卡（前缀匹配）
# export NCCL_IB_HCA="mlx5_0,mlx5_1"      # IB / RoCE 卡名（用 ibstat 查）。没 IB 就别开
# export NCCL_IB_DISABLE=0                # 1 = 强制走 TCP（无 IB 时的 fallback）
# export NCCL_NET_GDR_LEVEL=PHB           # GPU Direct RDMA 等级；看不懂别开

# ─── reward worker 子进程的 NCCL（与主训练独立，纯本机）──────────────────────
# reward_workers_main.py 已硬编码 NCCL_P2P_DISABLE=1 / NCCL_IB_DISABLE=1，
# 不会污染主训练的跨机 NCCL，无需在这里覆盖。

export HF_HUB_OFFLINE="${HF_HUB_OFFLINE:-1}"
export TRANSFORMERS_OFFLINE="${TRANSFORMERS_OFFLINE:-1}"
export WANDB_MODE="${WANDB_MODE:-disabled}"
